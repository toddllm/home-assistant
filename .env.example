# Shelly Plug US Gen4
SHELLY_IP=192.168.x.x
SHELLY_USER=admin
SHELLY_PASSWORD=your_shelly_password
SHELLY_DEVICE_ID=shellyplugusg4-xxxxxxxxxxxx
SHELLY_MAC=XXXXXXXXXXXX

# Gmail SMTP (for email notifications)
GMAIL_USER=your_email@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# Notification target (comma-separated for multiple recipients, defaults to GMAIL_USER if not set)
NOTIFY_EMAIL=your-email@gmail.com,smart-home-monitor@agentmail.to

# ntfy.sh push notifications
NTFY_TOPIC=your-private-topic-name

# Monitor thresholds (defaults shown, all optional)
POWER_THRESHOLD_WATTS=100.0
MAX_RUN_MINUTES=3
ACTIVE_POLL_SECONDS=5
OUTPUT_RECOVERY_GRACE_SECONDS=5
POWER_CYCLE_OFF_SECONDS=10
POWER_CYCLE_SETTLE_SECONDS=60
MAX_TEMP_C=60.0
TEMP_WARN_C=50.0
VOLTAGE_LOW=110.0
VOLTAGE_HIGH=130.0
RSSI_WARN=-80
PUMP_POWER_LOW=350.0
# Spring: 800 (higher water volume), Winter: 700
PUMP_POWER_HIGH=700.0
# Spring: 12, Winter: 24
NO_RUN_ALERT_HOURS=24
POLL_INTERVAL_SECONDS=30

# Tiered escalation (defaults shown — usually no need to change)
# Stuck float triggers: power cycle -> TIER_1 -> TIER_2 -> TIER_3
# TIER_1: 60s ON / 15 min OFF, escalates after 3 cycles (~45 min)
# TIER_2: 90s ON / 10 min OFF, escalates after 6 cycles (~66 min)
# TIER_3: 120s ON / 10 min OFF, max duty, alerts every cycle
# Weather risk from AI analyzer auto-adjusts rest periods if enabled
TIER_1_RUN_SECONDS=60
TIER_1_REST_SECONDS=900
TIER_1_ESCALATE_AFTER=3
TIER_2_RUN_SECONDS=90
TIER_2_REST_SECONDS=600
TIER_2_ESCALATE_AFTER=6
TIER_3_RUN_SECONDS=120
TIER_3_REST_SECONDS=600

# AI Analyzer (optional — runs on Mac with Ollama)
AI_ENABLED=false
AI_ANALYZER_URL=http://192.168.68.xxx:8078
AI_ANALYZER_PORT=8078
AI_MODEL=qwen3:32b-q4_K_M
OLLAMA_URL=http://localhost:11434
WEATHER_LAT=42.942
WEATHER_LON=-74.282

# Data source intervals (seconds, defaults shown)
ANALYSIS_INTERVAL=300
WEATHER_INTERVAL=3600
STREAM_INTERVAL=1800
NWS_INTERVAL=900
FORECAST_INTERVAL=21600
CORRELATION_INTERVAL=86400

# USGS stream gauge site IDs (comma-separated)
# Fort Hunter is at the Schoharie Creek / Mohawk River confluence
# 01349527 = Mohawk at Fonda (upstream), 01354083 = Mohawk at Amsterdam (downstream)
# 01351500 = Schoharie Creek at Burtonsville (upstream on creek)
USGS_SITE_IDS=01349527,01354083,01351500

# Data retention (days)
RETENTION_READINGS=30
RETENTION_ANALYSES=90
RETENTION_WEATHER=365
RETENTION_STREAM=365
